<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ConfiguracionModulos.MainPage">
    <VerticalStackLayout Padding="30" Spacing="20">
        <Label Text="Módulos de Hardware" FontSize="20" HorizontalOptions="Center" />
        <Button Text="Obtener GPS" Clicked="OnGetLocationClicked" />
        <Label x:Name="lblGPS" Text="Esperando datos..." />
        <Button Text="Verificar Red" Clicked="OnCheckNetworkClicked" />
        <Label x:Name="lblRed" Text="Estado de red: Desconocido" />
    </VerticalStackLayout>
</ContentPage>
